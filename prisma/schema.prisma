generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String
  name                String?
  imageUrl            String?
  aiOptimizations     AiOptimization[]
  /// Texte libre sous la zone structurée (si pas d’image d’en-tête pleine largeur)
  pdfHeaderText       String?
  pdfFooterText       String?
  /// Image d’en-tête / pied de page : si renseignées, remplacent la mise en page texte correspondante
  pdfHeaderImageUrl   String?
  pdfFooterImageUrl   String?
  pdfLogoUrl          String?
  pdfHeaderTitle      String?
  pdfHeaderAddress    String?
  /// JSON : tableau 2 lignes × 4 colonnes de chaînes
  pdfHeaderTableJson  String?
  /// stacked = logo+titre puis tableau pleine largeur ; logo_table_row = titre/adresse puis logo et tableau côte à côte
  pdfHeaderLayout     String   @default("stacked")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  invoices            Invoice[]
}

model Structure {
  id        String   @id @default(cuid())
  name      String
  region    String
  type      String
  siret     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("structures")
}

model LegalAlert {
  id          String   @id @default(cuid())
  title       String
  description String
  source      String
  url         String?
  pubDate     DateTime
  region      String   @default("france")
  seen        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("legal_alerts")
}

model Accountant {
  id        String   @id @default(cuid())
  region    String
  email     String
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]

  @@unique([region, email])
  @@map("accountants")
}

model Invoice {
  id              String      @id @default(cuid())
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename        String
  originalName    String
  size            Int
  mimeType        String
  ocrText         String?
  region          String
  accountantId    String?
  accountant      Accountant? @relation(fields: [accountantId], references: [id], onDelete: SetNull)
  sentAt          DateTime?
  amount          Float?
  category        String?
  status          String      @default("pending")
  invoiceDate     DateTime?
  fileUrl         String?
  shareToken      String?     @unique
  fournisseur     String?
  numeroFacture   String?
  montantHT       Float?
  montantTVA      Float?
  tauxTVA         Float?
  montantTTC      Float?
  structureId     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  aiOptimizations AiOptimization[]

  @@index([userId])
  @@map("invoices")
}

model AiOptimization {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  prompt    String
  response  String
  region    String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("ai_optimizations")
}

model SendHistory {
  id             String   @id @default(cuid())
  region         String
  recipientEmail String
  message        String
  filesCount     Int
  sentAt         DateTime @default(now())
  success        Boolean  @default(true)
  error          String?

  @@map("send_history")
}
